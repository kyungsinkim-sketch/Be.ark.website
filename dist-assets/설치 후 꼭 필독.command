#!/bin/bash
# ============================================================
#  Be.Ark — 설치 후 꼭 필독 (Read Me First)
#  더블클릭하면 자동으로 실행됩니다.
# ============================================================

# 이 스크립트가 있는 폴더로 이동 (DMG/다운로드 폴더 어디서든 동작)
cd "$(dirname "$0")" || cd "$HOME"

APP_NAME="Be.Ark.app"

clear
cat <<'BANNER'

   ____            _         _
  | __ )  ___     / \   _ __| | __
  |  _ \ / _ \   / _ \ | '__| |/ /
  | |_) |  __/  / ___ \| |  |   <
  |____/ \___| /_/   \_\_|  |_|\_\

  ──────────────────────────────────────────────
   환영합니다! Be.Ark 설치를 마무리할게요.
  ──────────────────────────────────────────────

BANNER

echo "  Be.Ark는 '로컬 우선' 개인 AI입니다."
echo "  대화 · 기억 · 작업 파일이 모두 빠불로의 컴퓨터 안에만 남습니다. 🔒"
echo ""
echo "  이 창은 macOS 보안(미서명 앱) 때문에 필요한 마지막 한 단계를"
echo "  자동으로 처리해 드립니다. 잠시만요..."
echo ""
sleep 1.5

# 1) 앱 위치 찾기: ① 이 스크립트 옆  ② /Applications  ③ ~/Downloads
APP_PATH=""
for CAND in "./$APP_NAME" "/Applications/$APP_NAME" "$HOME/Downloads/$APP_NAME" "$HOME/Desktop/$APP_NAME"; do
  if [ -d "$CAND" ]; then APP_PATH="$CAND"; break; fi
done

if [ -z "$APP_PATH" ]; then
  echo "  ⚠️  Be.Ark.app 을 찾지 못했어요."
  echo ""
  echo "     먼저 DMG 안의 'Be.Ark' 아이콘을 'Applications' 폴더로"
  echo "     드래그해서 설치한 뒤, 이 파일을 다시 더블클릭해 주세요."
  echo ""
  echo "  (창을 닫으셔도 됩니다.)"
  echo ""
  exit 1
fi

echo "  📦 찾았습니다:  $APP_PATH"
echo ""

# 2) 격리 속성 제거 (xattr -cr) — 미서명 앱 실행 차단 해제
echo "  🔧 보안 격리 속성을 정리하는 중..."
xattr -cr "$APP_PATH" 2>/dev/null
echo "  ✅ 완료!"
echo ""
sleep 0.8

# ── 간단 튜토리얼 ──────────────────────────────────────────
cat <<'TUTORIAL'
  ──────────────────────────────────────────────
   ⚡ 30초 시작 가이드
  ──────────────────────────────────────────────

   1. Be.Ark 가 곧 실행됩니다.
   2. 처음 켜면 'AI 모델'을 고르라고 해요.
        • 인터넷 없이 쓰고 싶다 → 로컬 모델 선택 (자동 다운로드)
        • 빠르게 써보고 싶다   → 본인 API 키 입력 (선택)
   3. 에이전트에게 이름·성격을 정해주면 끝!
        이제부터 그 친구는 빠불로를 기억합니다. 🧠

   💡 팁: 대화/기억/파일은 전부 이 컴퓨터에만 저장돼요.
         클라우드로 새어나가지 않습니다.

TUTORIAL

echo "  3초 후 Be.Ark 를 실행합니다..."
sleep 3

# 3) 앱 실행
open "$APP_PATH"

echo ""
echo "  🚀 실행했어요! 이 창은 닫으셔도 됩니다. 즐거운 시간 보내세요 🥰"
echo ""
